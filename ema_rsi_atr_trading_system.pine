//@version=6
strategy("EMA + RSI + ATR Trend System", overlay=true, initial_capital=10000, pyramiding=0, commission_type=strategy.commission.percent, commission_value=0.05)

// -------------------------
// Inputs
// -------------------------
fastLen      = input.int(20, "Fast EMA Length", minval=1)
slowLen      = input.int(50, "Slow EMA Length", minval=2)
rsiLen       = input.int(14, "RSI Length", minval=2)
rsiLongMin   = input.int(55, "Min RSI for Long", minval=1, maxval=100)
rsiShortMax  = input.int(45, "Max RSI for Short", minval=1, maxval=100)
atrLen       = input.int(14, "ATR Length", minval=1)
slATR        = input.float(1.8, "Stop Loss ATR Multiplier", step=0.1)
tpATR        = input.float(3.0, "Take Profit ATR Multiplier", step=0.1)
trailATR     = input.float(1.2, "Trailing ATR Multiplier", step=0.1)
useTrailing  = input.bool(true, "Use Trailing Stop")
tradeSession = input.session("0930-1600", "Trading Session")

// -------------------------
// Core calculations
// -------------------------
fastEMA = ta.ema(close, fastLen)
slowEMA = ta.ema(close, slowLen)
rsiVal  = ta.rsi(close, rsiLen)
atrVal  = ta.atr(atrLen)
inSess  = not na(time(timeframe.period, tradeSession))

trendUp   = fastEMA > slowEMA
trendDown = fastEMA < slowEMA

longSignal  = inSess and trendUp and ta.crossover(rsiVal, rsiLongMin)
shortSignal = inSess and trendDown and ta.crossunder(rsiVal, rsiShortMax)

// -------------------------
// Entries
// -------------------------
if longSignal and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)

if shortSignal and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)

// -------------------------
// Exits
// -------------------------
longStop   = strategy.position_avg_price - atrVal * slATR
longTarget = strategy.position_avg_price + atrVal * tpATR
shortStop  = strategy.position_avg_price + atrVal * slATR
shortTarget= strategy.position_avg_price - atrVal * tpATR

if strategy.position_size > 0
    if useTrailing
        strategy.exit("Long Exit", "Long", stop=longStop, limit=longTarget, trail_offset=atrVal * trailATR)
    else
        strategy.exit("Long Exit", "Long", stop=longStop, limit=longTarget)

if strategy.position_size < 0
    if useTrailing
        strategy.exit("Short Exit", "Short", stop=shortStop, limit=shortTarget, trail_offset=atrVal * trailATR)
    else
        strategy.exit("Short Exit", "Short", stop=shortStop, limit=shortTarget)

// Optional trend-failure protection
if strategy.position_size > 0 and trendDown
    strategy.close("Long", comment="Trend flip")

if strategy.position_size < 0 and trendUp
    strategy.close("Short", comment="Trend flip")

// -------------------------
// Visuals
// -------------------------
plot(fastEMA, "Fast EMA", color=color.teal, linewidth=2)
plot(slowEMA, "Slow EMA", color=color.orange, linewidth=2)

plotshape(longSignal, title="Long Signal", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.tiny, text="L")
plotshape(shortSignal, title="Short Signal", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny, text="S")

bgcolor(inSess ? na : color.new(color.gray, 92), title="Out of Session")
